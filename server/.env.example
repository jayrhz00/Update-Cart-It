# -----------------------------------------------------------------------------
# Cart-It server environment (copy to `.env` and fill in real values)
#
# HOW THIS FILE MAPS TO THE CODE (for students)
#   - `db.ts` reads DATABASE_URL to build the Postgres pool.
#   - `index.ts` reads JWT_SECRET to sign/verify login tokens and password-reset tokens.
#   - Email-related routes read RESEND_* and FRONTEND_URL when sending links.
# -----------------------------------------------------------------------------

# Local Postgres (create DB first — see server/scripts/create_database_cart_it.sql)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/cart_it

# Neon / Render / any Postgres provider: full connection string the `pg` library understands.
DATABASE_URL=your_neon_database_url_here

# Port the Express server listens on (your React app’s `api.js` must point at the same port in dev).
PORT=5001

# Secret key for JWT — long random string in real life. Never commit the real `.env` to Git.
JWT_SECRET=...

# Base URL of the React site. Used to build links in emails (password reset, invites). Must match where users open the app.
# Production custom domain (Cloudflare). Use https://cart-it.pages.dev for staging only.
FRONTEND_URL=https://cart-it.com

# Optional: log POST /api/cart-items bodies to Render logs (set to 1 while debugging the extension).
# DEBUG_CART_POST=1

# Resend (https://resend.com): password reset, invites, price-drop, and out-of-stock emails. Leave blank to skip mail.
RESEND_API_KEY=

# "From" address Resend accepts for your domain (example uses their onboarding sender).
RESEND_FROM_EMAIL=Cart-It <onboarding@resend.dev>

# How long password-reset links stay valid (minutes).
RESET_PASSWORD_EXP_MINUTES=30

# -----------------------------------------------------------------------------
# ScrapingBee (https://www.scrapingbee.com) — server-side HTML fetch fallback
# -----------------------------------------------------------------------------
# Used in server/index.ts → fetchHtmlViaScrapingBee / fetchHtmlForProductUrl when a plain
# Node fetch returns bot walls or HTML without a parseable price (common on Amazon).
SCRAPINGBEE_API_KEY=
# Set to false to force direct fetch only (class demos / save quota).
# SCRAPINGBEE_ENABLED=false
# Optional: residential proxy tier (uses more credits).
# SCRAPINGBEE_PREMIUM_PROXY=1
# When true (default), POST /api/cart-items for amazon.com re-fetches HTML via ScrapingBee and prefers server price + image over the extension DOM scrape.
# SCRAPINGBEE_ENRICH_AMAZON=false

# -----------------------------------------------------------------------------
# Price / stock checks (in-app notifications + optional Resend emails)
# -----------------------------------------------------------------------------
# In-process timer: runs automatically while the Node server is up (default every 180 minutes).
# Minimum interval enforced in code: 5 minutes.
PRICE_CHECK_INTERVAL_MINUTES=180
# Disable entirely for demos:
# PRICE_CHECK_ENABLED=false
# Or: PRICE_CHECK_INTERVAL_MINUTES=0
#
# Optional: same secret on Render “Cron Job” + this API service. POST with header:
#   X-Cart-It-Cron-Secret: <your secret>
# to /api/internal/run-price-check so checks still run if the web instance sleeps (free tier).
PRICE_CHECK_CRON_SECRET=

# -----------------------------------------------------------------------------
# ScrapingBee — server fetches public product pages when Amazon blocks plain Node `fetch`
# (product images, price backfill, background price checks). Sign up at https://www.scrapingbee.com
# -----------------------------------------------------------------------------
# SCRAPINGBEE_API_KEY=
# Amazon often needs a residential proxy; enable if images/price are still empty (uses more credits):
# SCRAPINGBEE_PREMIUM_PROXY=1
