{
  "manifest_version": 3,
  "name": "cart-It",
  "version": "1.0.2",
  "description": "Save items from any site, collaborate and chat in shared lists, track prices and stock, and add notes.",
  "background": {
    "scripts": [
      "config.js",
      "background.js"
    ]
  },
  "action": {
    "default_title": "cart-It",
    "default_popup": "sidepanel.html",
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cart-it.com/*",
        "https://www.cart-it.com/*",
        "https://*.cart-it.com/*",
        "https://cart-it.pages.dev/*",
        "https://*.cart-it.pages.dev/*",
        "https://cart-it-com.pages.dev/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "https://127.0.0.1/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cart-it@cart-it.pages.dev",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
