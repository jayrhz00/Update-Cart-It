{
  "manifest_version": 3,
  "name": "cart-It",
  "version": "1.0.2",
  "description": "Save items from any site, collaborate and chat in shared lists, track prices and stock, and add notes.",
  "minimum_chrome_version": "114",
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "cart-It",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": [
        "https://cart-it.com/*",
        "https://www.cart-it.com/*",
        "https://*.cart-it.com/*",
        "https://cart-it.pages.dev/*",
        "https://*.cart-it.pages.dev/*",
        "https://cart-it-com.pages.dev/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "https://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
